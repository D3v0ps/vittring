<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }} — Vittring</title>
  <link rel="stylesheet" href="/static/css/main.css" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <a href="/" class="brand">Vittring</a>
      <nav class="topnav">
        {% if user %}
          <a href="/app" class="{% if request.url.path == '/app' %}active{% endif %}">Konto</a>
          <a href="/app/subscriptions" class="{% if request.url.path.startswith('/app/subscriptions') %}active{% endif %}">Prenumerationer</a>
          <a href="/app/account">Inställningar</a>
          <form method="post" action="/auth/logout" style="display:inline">
            <input type="hidden" name="csrf" value="" />
            <button type="submit" class="btn btn-ghost">Logga ut</button>
          </form>
          <span class="avatar">{{ (user.full_name or user.email)[:1].upper() }}</span>
        {% else %}
          <a href="/pricing">Priser</a>
          <a href="/auth/login">Logga in</a>
          <a href="/auth/signup" class="btn btn-secondary">Skapa konto</a>
        {% endif %}
      </nav>
    </div>
  </header>

  <main>
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-row">
        <span>Vittring</span>
        <a href="/legal/privacy">Integritetspolicy</a>
        <a href="/legal/terms">Användarvillkor</a>
        <a href="mailto:info@karimkhalil.se">Kontakt</a>
        <span style="margin-left:auto;">© 2026 Karim Khalil</span>
      </div>
    </div>
  </footer>
</body>
</html>
