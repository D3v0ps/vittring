{% extends "auth/_auth_base.html.j2" %}
{% block auth_content %}
{% if submitted %}
  <h1 class="auth-h1">Kolla din <em>inkorg</em>.</h1>
  <p class="auth-sub">Om e-postadressen finns hos oss har vi skickat en återställningslänk. Den är giltig i 1 timme.</p>
  <a href="/auth/login" class="v-button v-button--ghost-dark v-button--lg v-button--block">Till inloggning →</a>
{% else %}
  <h1 class="auth-h1">Återställ <em>lösenord</em>.</h1>
  <p class="auth-sub">Ange e-postadressen som hör till ditt konto. Vi skickar en länk för att välja nytt lösenord.</p>
  <form method="post" action="/auth/password-reset" class="auth-form">
    {{ csrf_input() }}
    <div class="field">
      <label for="email">E-post</label>
      <input class="input" type="email" id="email" name="email" required autocomplete="email" placeholder="namn@företag.se" />
    </div>
    <button type="submit" class="v-button v-button--full-signal v-button--lg v-button--block">Skicka återställningslänk →</button>
  </form>
  <p class="auth-foot">Kom du på det? <a href="/auth/login">Logga in</a></p>
{% endif %}
{% endblock %}
