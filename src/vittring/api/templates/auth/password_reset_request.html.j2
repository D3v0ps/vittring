{% extends "_layout.html.j2" %}
{% block content %}
<section class="auth-shell">
  <div class="auth-card">
    <a href="/" class="auth-mark">
      <span class="auth-mark-dot"></span>
      Vittring
    </a>
    {% if submitted %}
      <div class="auth-state">
        <div class="auth-state-icon auth-state-icon-pending">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 7.5l9 6 9-6M3 7.5v9a1.5 1.5 0 001.5 1.5h15a1.5 1.5 0 001.5-1.5v-9M3 7.5L4.5 6h15L21 7.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h1>Kolla din inkorg</h1>
        <p>Om e-postadressen finns hos oss har vi skickat en återställningslänk. Den är giltig i 1 timme.</p>
      </div>
      <div class="auth-divider"></div>
      <a href="/auth/login" class="btn btn-secondary" style="width: 100%;">Till inloggning</a>
    {% else %}
      <h1 class="auth-heading">Återställ lösenord</h1>
      <p class="auth-sub">Ange e-postadressen som hör till ditt konto. Vi skickar en länk för att välja nytt lösenord.</p>
      <form method="post" action="/auth/password-reset" class="auth-form">
      {{ csrf_input() }}
        <div class="field">
          <label for="email">E-post</label>
          <input class="input" type="email" id="email" name="email" required autocomplete="email" placeholder="namn@företag.se" />
        </div>
        <button type="submit" class="btn btn-primary btn-lg">Skicka återställningslänk</button>
      </form>
      <p class="auth-foot">
        Kom du på det? <a href="/auth/login">Logga in</a>
      </p>
    {% endif %}
  </div>
</section>
{% endblock %}
