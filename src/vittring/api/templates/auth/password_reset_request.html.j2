{% extends "_layout.html.j2" %}
{% block content %}
<section class="auth-shell">
  <h1>Återställ lösenord</h1>
  {% if submitted %}
    <p>Om e-postadressen finns i vårt system har vi skickat en återställningslänk. Den är giltig i 1 timme.</p>
    <a href="/auth/login" class="btn btn-secondary">Till inloggning</a>
  {% else %}
    <p>Ange e-postadressen som hör till ditt konto, så skickar vi en länk för att välja nytt lösenord.</p>
    <form method="post" action="/auth/password-reset">
      <div class="field">
        <label for="email">E-post</label>
        <input class="input" type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <button type="submit" class="btn btn-primary">Skicka länk</button>
    </form>
  {% endif %}
</section>
{% endblock %}
