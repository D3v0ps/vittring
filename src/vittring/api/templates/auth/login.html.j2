{% extends "_layout.html.j2" %}
{% block content %}
<section class="auth-shell">
  <h1>Logga in</h1>
  {% if error %}
    <div class="alert-error">{{ error }}</div>
  {% endif %}
  <form method="post" action="/auth/login">
    <div class="field">
      <label for="email">E-post</label>
      <input class="input" type="email" id="email" name="email" value="{{ email_value or '' }}" required autocomplete="email" />
    </div>
    <div class="field">
      <label for="password">Lösenord</label>
      <input class="input" type="password" id="password" name="password" required autocomplete="current-password" />
    </div>
    {% if require_2fa %}
    <div class="field">
      <label for="totp">Tvåfaktorskod</label>
      <input class="input mono" type="text" id="totp" name="totp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" required />
    </div>
    {% endif %}
    <button type="submit" class="btn btn-primary">Logga in</button>
  </form>
  <p class="subtle" style="margin-top: 24px;">
    <a href="/auth/password-reset">Glömt lösenordet?</a> · <a href="/auth/signup">Skapa konto</a>
  </p>
</section>
{% endblock %}
