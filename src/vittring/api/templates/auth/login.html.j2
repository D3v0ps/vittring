{% extends "auth/_auth_base.html.j2" %}
{% block auth_content %}
<h1 class="auth-h1">{% if require_2fa %}Bekräfta <em>inloggning</em>.{% else %}Välkommen <em>tillbaka</em>.{% endif %}</h1>
<p class="auth-sub">
  {% if require_2fa %}
    Ange koden från din authenticator-app för att slutföra inloggningen.
  {% else %}
    Logga in för att se dagens digest.
  {% endif %}
</p>
{% if error %}<div class="auth-error">{{ error }}</div>{% endif %}
<form method="post" action="/auth/login" class="auth-form">
  {{ csrf_input() }}
  {% if next %}<input type="hidden" name="next" value="{{ next }}" />{% endif %}
  <div class="field">
    <label for="email">E-post</label>
    <input class="input" type="email" id="email" name="email" value="{{ email_value or '' }}" required autocomplete="email" placeholder="namn@företag.se" />
  </div>
  <div class="field">
    <label for="password">Lösenord</label>
    <input class="input" type="password" id="password" name="password" required autocomplete="current-password" />
  </div>
  {% if require_2fa %}
  <div class="field">
    <label for="totp">Tvåfaktorskod</label>
    <input class="input mono" type="text" id="totp" name="totp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" required autofocus placeholder="123 456" />
  </div>
  {% endif %}
  <button type="submit" class="v-button v-button--full-signal v-button--lg v-button--block">
    {% if require_2fa %}Bekräfta och logga in →{% else %}Logga in →{% endif %}
  </button>
</form>
<p class="auth-foot">
  <a href="/auth/password-reset">Glömt lösenordet?</a> · <a href="/auth/signup">Skapa konto</a>
</p>
{% endblock %}
