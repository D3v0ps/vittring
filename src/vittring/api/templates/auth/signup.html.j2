{% extends "auth/_auth_base.html.j2" %}
{% block auth_content %}
<h1 class="auth-h1">Starta din <em>provperiod</em>.</h1>
<p class="auth-sub">14 dagar gratis. Inget kreditkort. Avbryt när du vill.</p>
{% if error %}<div class="auth-error">{{ error }}</div>{% endif %}
<form method="post" action="/auth/signup" class="auth-form">
  {{ csrf_input() }}
  <div class="field">
    <label for="email">E-post</label>
    <input class="input" type="email" id="email" name="email" required autocomplete="email" placeholder="namn@företag.se" />
  </div>
  <div class="field">
    <label for="full_name">Namn</label>
    <input class="input" type="text" id="full_name" name="full_name" autocomplete="name" placeholder="För- och efternamn" />
  </div>
  <div class="field">
    <label for="company_name">Företag</label>
    <input class="input" type="text" id="company_name" name="company_name" autocomplete="organization" placeholder="t.ex. Acme Bemanning AB" />
  </div>
  <div class="field">
    <label for="password">Lösenord</label>
    <input class="input" type="password" id="password" name="password" required minlength="12" autocomplete="new-password" />
    <div class="helper">Minst 12 tecken. Använd gärna en lösenfras.</div>
  </div>
  <button type="submit" class="v-button v-button--full-signal v-button--lg v-button--block">Skapa konto →</button>
  <p style="margin-top: 12px; font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); text-align: center;">Inget kreditkort krävs · Radera kontot när du vill</p>
</form>
<p class="auth-foot">Har du redan ett konto? <a href="/auth/login">Logga in</a></p>
{% endblock %}
