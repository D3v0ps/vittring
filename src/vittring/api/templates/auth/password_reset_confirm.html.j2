{% extends "_layout.html.j2" %}
{% block content %}
<section class="auth-shell">
  <h1>Välj nytt lösenord</h1>
  {% if error %}
    <div class="alert-error">{{ error }}</div>
  {% endif %}
  <form method="post" action="/auth/password-reset/confirm">
    <input type="hidden" name="t" value="{{ token }}" />
    <div class="field">
      <label for="password">Nytt lösenord (minst 12 tecken)</label>
      <input class="input" type="password" id="password" name="password" required minlength="12" autocomplete="new-password" />
    </div>
    <button type="submit" class="btn btn-primary">Spara nytt lösenord</button>
  </form>
</section>
{% endblock %}
