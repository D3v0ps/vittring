{% extends "_layout.html.j2" %}
{% block content %}
<section class="auth-shell">
  <div class="auth-card">
    <a href="/" class="auth-mark">
      <span class="auth-mark-dot"></span>
      Vittring
    </a>
    <h1 class="auth-heading">Välj nytt lösenord</h1>
    <p class="auth-sub">Ditt nya lösenord ersätter det gamla direkt. Logga sedan in som vanligt.</p>
    {% if error %}
      <div class="alert-error">{{ error }}</div>
    {% endif %}
    <form method="post" action="/auth/password-reset/confirm" class="auth-form">
      <input type="hidden" name="t" value="{{ token }}" />
      <div class="field">
        <label for="password">Nytt lösenord</label>
        <input class="input" type="password" id="password" name="password" required minlength="12" autocomplete="new-password" autofocus />
        <span class="password-requirements">Minst 12 tecken. Använd gärna en lösenfras.</span>
      </div>
      <button type="submit" class="btn btn-primary btn-lg">Spara nytt lösenord</button>
    </form>
    <p class="auth-foot">
      <a href="/auth/login">Tillbaka till inloggning</a>
    </p>
  </div>
</section>
{% endblock %}
