{% extends "auth/_auth_base.html.j2" %}
{% block auth_content %}
<h1 class="auth-h1">Välj nytt <em>lösenord</em>.</h1>
<p class="auth-sub">Ditt nya lösenord ersätter det gamla direkt. Logga sedan in som vanligt.</p>
{% if error %}<div class="auth-error">{{ error }}</div>{% endif %}
<form method="post" action="/auth/password-reset/confirm" class="auth-form">
  {{ csrf_input() }}
  <input type="hidden" name="t" value="{{ token }}" />
  <div class="field">
    <label for="password">Nytt lösenord</label>
    <input class="input" type="password" id="password" name="password" required minlength="12" autocomplete="new-password" autofocus />
    <div class="helper">Minst 12 tecken. Använd gärna en lösenfras.</div>
  </div>
  <button type="submit" class="v-button v-button--full-signal v-button--lg v-button--block">Spara nytt lösenord →</button>
</form>
<p class="auth-foot"><a href="/auth/login">Tillbaka till inloggning</a></p>
{% endblock %}
