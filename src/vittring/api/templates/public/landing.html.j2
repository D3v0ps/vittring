{% extends "_layout.html.j2" %}
{% block content %}
<style>
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  @media (max-width: 980px) { .hero-grid { grid-template-columns: 1fr; gap: 40px; } }

  .hero-h1 {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(56px, 7vw, 112px); line-height: 0.95;
    letter-spacing: -0.035em; color: var(--v-paper); margin: 0 0 24px;
  }
  .hero-h1 em { color: var(--v-signal); font-style: italic; }
  .hero-lede {
    font-family: var(--font-sans); font-size: 19px; line-height: 1.5;
    color: var(--v-mist); max-width: 520px; margin: 0 0 40px;
  }

  .live-badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 8px 14px; border-radius: var(--r-pill);
    background: rgba(184,224,74,0.08);
    border: 1px solid rgba(184,224,74,0.25);
    margin-bottom: 32px;
  }

  .ticker {
    margin-top: 56px; padding: 16px;
    background: rgba(200,204,196,0.04);
    border: 1px solid rgba(200,204,196,0.1);
    border-radius: var(--r-2); max-width: 560px;
  }
  .ticker-row {
    display: grid; grid-template-columns: 60px 60px 1fr; gap: 12px;
    font-family: var(--font-mono); font-size: 12px;
    padding: 6px 0; color: var(--v-mist);
  }
  .ticker-row + .ticker-row { border-top: 1px dashed rgba(200,204,196,0.08); }

  .preview-card {
    background: var(--v-night-2); border-radius: var(--r-3);
    border: 1px solid var(--v-night-3);
    box-shadow: var(--shadow-night); overflow: hidden;
  }
  .preview-tab {
    padding: 12px 16px; border-bottom: 1px solid var(--v-night-3);
    display: flex; align-items: center; gap: 12px;
  }
  .preview-dots { display: flex; gap: 5px; }
  .preview-dots span { width: 10px; height: 10px; border-radius: 50%; }
  .preview-stat {
    padding: 24px; border-bottom: 1px solid var(--v-night-3);
  }
  .preview-row {
    padding: 14px 24px; border-top: 1px solid var(--v-night-3);
    border-left: 3px solid transparent;
  }
  .preview-row.priority { background: rgba(184,224,74,0.05); border-left-color: var(--v-signal); }
  .preview-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 4px; }
  .preview-time { font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); }
  .preview-row.priority .preview-time { color: var(--v-signal); }
  .preview-pill {
    font-family: var(--font-mono); font-size: 9px; padding: 2px 7px;
    border-radius: var(--r-pill); border: none;
  }
  .preview-pill--neutral { background: var(--v-night-3); color: var(--v-mist); }
  .preview-pill--amber { background: rgba(200,117,62,0.15); color: var(--v-amber); }
  .preview-title { font-size: 14px; font-weight: 500; color: var(--v-paper); margin-bottom: 2px; }
  .preview-subtitle { font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); }

  .preview-annotation {
    position: absolute; right: -24px; top: 100px;
    background: var(--v-signal); color: var(--v-signal-ink);
    padding: 10px 14px; border-radius: var(--r-2);
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    box-shadow: var(--shadow-2);
  }

  .step-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;
    border-top: 1px solid var(--v-night-3); border-bottom: 1px solid var(--v-night-3);
  }
  @media (max-width: 880px) { .step-grid { grid-template-columns: 1fr; } }
  .step-cell { padding: 40px; border-left: 1px solid var(--v-night-3); }
  .step-cell:first-child { border-left: none; }
  @media (max-width: 880px) {
    .step-cell { border-left: none; border-top: 1px solid var(--v-night-3); }
    .step-cell:first-child { border-top: none; }
  }
  .step-num { font-family: var(--font-mono); font-size: 11px; color: var(--v-signal); margin-bottom: 32px; letter-spacing: 0.1em; }
  .step-title { font-family: var(--font-display); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 12px; color: var(--v-paper); }
  .step-desc { font-size: 15px; line-height: 1.5; color: var(--v-mist); max-width: 320px; }

  .source-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 880px) { .source-grid { grid-template-columns: 1fr; } }

  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 880px) { .compare-grid { grid-template-columns: 1fr; } }

  .pitch-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 880px) { .pitch-grid { grid-template-columns: 1fr; } }
  .pitch-card {
    border: 1px solid var(--v-night-3); border-left: 3px solid var(--v-amber);
    border-radius: var(--r-3); padding: 32px; background: var(--v-night);
  }
  .pitch-eyebrow { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; color: var(--v-amber); margin-bottom: 12px; }
  .pitch-headline { font-family: var(--font-display); font-size: 22px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.2; color: var(--v-paper); margin-bottom: 16px; }
  .pitch-body { font-size: 14px; line-height: 1.5; color: var(--v-mist); }

  .integ-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; align-items: start; }
  @media (max-width: 880px) { .integ-grid { grid-template-columns: 1fr; gap: 24px; } }
  .integ-tools { display: flex; flex-wrap: wrap; gap: 8px; }
  .integ-tool {
    font-family: var(--font-mono); font-size: 12px;
    padding: 6px 12px; border-radius: var(--r-pill);
    background: var(--v-night); border: 1px solid var(--v-night-3);
    color: var(--v-paper);
  }
  .integ-list { list-style: none; padding: 0; margin: 0; }
  .integ-list li { padding: 14px 0; border-top: 1px solid var(--v-night-3); font-size: 15px; color: var(--v-mist); line-height: 1.5; display: flex; gap: 12px; }
  .integ-list li:first-child { border-top: none; }
  .integ-list .label { font-family: var(--font-mono); font-size: 11px; color: var(--v-signal); flex-shrink: 0; min-width: 90px; padding-top: 2px; letter-spacing: 0.05em; }
  .source-card {
    border: 1px solid var(--v-night-3); border-radius: var(--r-3);
    padding: 32px; background: var(--v-night);
    position: relative; overflow: hidden;
  }
  .source-name { font-family: var(--font-display); font-size: 26px; font-weight: 500; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--v-paper); }
  .source-url { font-family: var(--font-mono); font-size: 11px; color: var(--v-signal); margin-bottom: 16px; }
  .source-desc { font-size: 14px; line-height: 1.5; color: var(--v-mist); }

  .testimonial-block {
    background: var(--v-night); border: 1px solid var(--v-night-3);
    border-radius: var(--r-4); padding: 64px;
    position: relative; overflow: hidden;
  }
  .testimonial-quote {
    font-family: var(--font-display); font-size: clamp(28px, 3.4vw, 42px);
    font-weight: 400; line-height: 1.15; letter-spacing: -0.025em;
    color: var(--v-paper);
  }

  .faq-grid { display: grid; grid-template-columns: 1fr 1.6fr; gap: 80px; }
  @media (max-width: 880px) { .faq-grid { grid-template-columns: 1fr; gap: 32px; } }
  .faq-list { border-top: 1px solid var(--v-night-3); }
  .faq-list details { border-bottom: 1px solid var(--v-night-3); padding: 20px 0; }
  .faq-list summary {
    cursor: pointer; list-style: none;
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-display); font-size: 22px; font-weight: 500;
    letter-spacing: -0.02em; color: var(--v-paper);
  }
  .faq-list summary::-webkit-details-marker { display: none; }
  .faq-list .plus { font-family: var(--font-mono); font-size: 18px; color: var(--v-signal); transition: transform 0.2s; }
  .faq-list details[open] .plus { transform: rotate(45deg); }
  .faq-list .faq-a { padding-top: 16px; font-size: 16px; line-height: 1.5; color: var(--v-mist); max-width: 720px; }

  .final-cta {
    max-width: 1280px; margin: 0 auto; border-radius: var(--r-4);
    background: var(--v-night); border: 1px solid var(--v-night-3);
    padding: 80px 64px; position: relative; overflow: hidden; color: var(--v-paper);
  }
  .final-cta-radar { position: absolute; right: -120px; top: -120px; opacity: 0.4; }
  .final-cta h2 {
    font-family: var(--font-display); font-size: clamp(48px, 6vw, 88px);
    font-weight: 400; letter-spacing: -0.03em; line-height: 0.95; margin: 0 0 24px;
  }
  .final-cta h2 em { color: var(--v-signal); font-style: italic; }
</style>

<!-- HERO -->
<section style="position: relative; padding: 64px 48px 80px; overflow: hidden;
  background-image:
    radial-gradient(circle at 50% 100%, rgba(184,224,74,0.06) 0%, transparent 60%),
    linear-gradient(to right, rgba(200,204,196,0.04) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(200,204,196,0.04) 1px, transparent 1px);
  background-size: 100% 100%, 48px 48px, 48px 48px;">
  <div style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); opacity: 0.6; pointer-events: none;">
    <svg width="900" height="900" viewBox="0 0 480 480" fill="none">
      <circle cx="240" cy="240" r="60" stroke="rgba(200,204,196,0.15)" stroke-width="0.5"/>
      <circle cx="240" cy="240" r="120" stroke="rgba(200,204,196,0.15)" stroke-width="0.5"/>
      <circle cx="240" cy="240" r="180" stroke="rgba(200,204,196,0.15)" stroke-width="0.5"/>
      <circle cx="240" cy="240" r="240" stroke="rgba(200,204,196,0.15)" stroke-width="0.5"/>
      <circle cx="240" cy="240" r="3" fill="var(--v-signal)"/>
      <circle cx="320" cy="180" r="3" fill="var(--v-signal)"/>
      <circle cx="160" cy="290" r="3" fill="var(--v-signal)"/>
      <line x1="240" y1="240" x2="420" y2="120" stroke="var(--v-signal)" stroke-width="0.5" opacity="0.5"/>
    </svg>
  </div>

  <div style="position: relative; max-width: 1280px; margin: 0 auto;">
    <div class="hero-grid">
      <div>
        <div class="live-badge">
          <span class="v-radar-dot"></span>
          <span class="t-mono" style="font-size: 11px; color: var(--v-signal); letter-spacing: 0.08em;">— LIVE · 3 KÄLLOR ÖVERVAKAS —</span>
        </div>

        <h1 class="hero-h1">Hitta företag som behöver personal — <em>innan dina konkurrenter ringer.</em></h1>

        <p class="hero-lede">Spara 5–10 timmar research per vecka. Få dagliga säljsignaler från jobbannonser, bolagshändelser och offentliga upphandlingar — kurerade efter din nisch.</p>

        <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
          <a href="/auth/signup" class="v-button v-button--signal v-button--lg">Starta provperiod →</a>
          <a href="/demo" class="v-button v-button--ghost-dark v-button--lg">Se exempel på signaler</a>
        </div>

        <div class="ticker">
          <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
            <span class="t-mono" style="font-size: 10px; color: var(--v-ink-4); letter-spacing: 0.08em;">SENASTE 60 MIN</span>
            <span class="t-mono" style="font-size: 10px; color: var(--v-signal);">● 12 nya</span>
          </div>
          <div class="ticker-row">
            <span style="color: var(--v-ink-4);">16:42</span>
            <span style="color: var(--v-amber);">Upph.</span>
            <span>Region Stockholm — Ramavtal lager</span>
          </div>
          <div class="ticker-row">
            <span style="color: var(--v-ink-4);">16:18</span>
            <span style="color: var(--v-mist);">Jobb</span>
            <span>Postnord 18 truckförare · Rosersberg</span>
          </div>
          <div class="ticker-row">
            <span style="color: var(--v-ink-4);">15:54</span>
            <span style="color: var(--v-mist);">Bolag</span>
            <span>Ahlsell Logistik AB · Ny VD</span>
          </div>
        </div>
      </div>

      <!-- Right: dashboard preview -->
      <div style="position: relative;">
        <div class="preview-card">
          <div class="preview-tab">
            <div class="preview-dots">
              <span style="background: #FF5F56;"></span>
              <span style="background: #FFBD2E;"></span>
              <span style="background: #27C93F;"></span>
            </div>
            <span class="t-mono" style="font-size: 11px; color: var(--v-ink-4);">app.vittring.se / digest</span>
          </div>

          <div class="preview-stat">
            <div class="t-mono" style="font-size: 10px; color: var(--v-ink-4); letter-spacing: 0.1em; margin-bottom: 8px;">SIGNALER · 7 DYGN</div>
            <div style="display: flex; align-items: baseline; gap: 12px;">
              <span style="font-family: var(--font-display); font-size: 64px; line-height: 1; color: var(--v-paper);">214</span>
              <span class="t-mono" style="font-size: 13px; color: var(--v-signal);">+18% v/v</span>
            </div>
            <svg viewBox="0 0 320 60" style="width: 100%; margin-top: 12px;">
              <defs>
                <linearGradient id="sparkB" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0" stop-color="#B8E04A" stop-opacity="0.3"/>
                  <stop offset="1" stop-color="#B8E04A" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M0,45 L40,42 L80,38 L120,40 L160,28 L200,30 L240,18 L280,22 L320,12 L320,60 L0,60 Z" fill="url(#sparkB)"/>
              <polyline points="0,45 40,42 80,38 120,40 160,28 200,30 240,18 280,22 320,12" fill="none" stroke="var(--v-signal)" stroke-width="1.5"/>
              <circle cx="320" cy="12" r="3" fill="var(--v-signal)"/>
            </svg>
          </div>

          <div>
            <div class="preview-row priority">
              <div class="preview-meta">
                <span class="preview-time">16:42</span>
                <span class="preview-pill preview-pill--amber">Upph.</span>
              </div>
              <div class="preview-title">Region Stockholm — Ramavtal lager</div>
              <div class="preview-subtitle">12 mkr · CPV 79620000</div>
            </div>
            <div class="preview-row">
              <div class="preview-meta">
                <span class="preview-time">14:32</span>
                <span class="preview-pill preview-pill--neutral">Jobb</span>
              </div>
              <div class="preview-title">Postnord söker 18 truckförare</div>
              <div class="preview-subtitle">Rosersberg · SNI 53.100</div>
            </div>
            <div class="preview-row">
              <div class="preview-meta">
                <span class="preview-time">09:15</span>
                <span class="preview-pill preview-pill--neutral">Bolag</span>
              </div>
              <div class="preview-title">Ahlsell Logistik · Ny VD</div>
              <div class="preview-subtitle">SE5567231223</div>
            </div>
          </div>
        </div>

        <div class="preview-annotation">↘ ny signal<br><span style="opacity: 0.7;">1 min sedan</span></div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="features" style="padding: 96px 48px 0; background: var(--v-night-2);">
  <div style="max-width: 1280px; margin: 0 auto;">
    <div style="margin-bottom: 48px;">
      <div class="t-eyebrow" style="color: var(--v-signal);">03 STEG</div>
      <h2 style="font-family: var(--font-display); font-size: clamp(36px, 4.5vw, 56px); font-weight: 400; letter-spacing: -0.025em; line-height: 1.05; margin: 8px 0 0; color: var(--v-paper); max-width: 800px;">
        Från registrering till första samtalet — <em style="color: var(--v-signal); font-style: italic;">samma vecka.</em>
      </h2>
    </div>
    <div class="step-grid">
      <div class="step-cell">
        <div class="step-num">01</div>
        <div class="step-title">Beskriv din nisch</div>
        <div class="step-desc">Roller, kommuner, SNI- och CPV-koder, nyckelord. Justera när du vill.</div>
      </div>
      <div class="step-cell">
        <div class="step-num">02</div>
        <div class="step-title">Vi filtrerar bruset</div>
        <div class="step-desc" style="font-style: italic; color: var(--v-paper);">"Av 4 982 inkommande signaler igår matchade 12 din profil."</div>
      </div>
      <div class="step-cell">
        <div class="step-num">03</div>
        <div class="step-title">Du läser ditt mejl</div>
        <div class="step-desc">06:30 ligger digesten i inboxen. Klart, daterat, direktlänkat.</div>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 0; border-bottom: 1px solid var(--v-night-3);">
      <div style="padding: 32px 40px; border-left: 1px solid var(--v-night-3);">
        <div style="font-family: var(--font-display); font-size: 36px; font-weight: 400; letter-spacing: -0.02em; color: var(--v-paper);">06:30</div>
        <div class="t-mono" style="font-size: 11px; color: var(--v-ink-4); letter-spacing: 0.08em; margin-top: 4px;">DAGLIG LEVERANS</div>
      </div>
      <div style="padding: 32px 40px; border-left: 1px solid var(--v-night-3);">
        <div style="font-family: var(--font-display); font-size: 36px; font-weight: 400; letter-spacing: -0.02em; color: var(--v-paper);">3 källor</div>
        <div class="t-mono" style="font-size: 11px; color: var(--v-ink-4); letter-spacing: 0.08em; margin-top: 4px;">JOBB · BOLAG · UPPHANDLING</div>
      </div>
      <div style="padding: 32px 40px; border-left: 1px solid var(--v-night-3);">
        <div style="font-family: var(--font-display); font-size: 36px; font-weight: 400; letter-spacing: -0.02em; color: var(--v-paper);">EU residency</div>
        <div class="t-mono" style="font-size: 11px; color: var(--v-ink-4); letter-spacing: 0.08em; margin-top: 4px;">HETZNER FALKENSTEIN</div>
      </div>
    </div>
  </div>
</section>

<!-- BEFORE / AFTER -->
<section style="padding: 96px 48px; background: var(--v-night-2);">
  <div style="max-width: 1280px; margin: 0 auto;">
    <div class="t-eyebrow" style="color: var(--v-ink-4); margin-bottom: 16px;">SKILLNADEN</div>
    <h2 style="font-family: var(--font-display); font-size: clamp(40px, 5vw, 64px); font-weight: 400; letter-spacing: -0.03em; line-height: 1; margin: 0 0 48px; color: var(--v-paper);">
      Före och <em style="color: var(--v-signal); font-style: italic;">efter</em> Vittring.
    </h2>

    <div class="compare-grid">
      <div style="border: 1px solid var(--v-night-3); border-left: 3px solid var(--v-amber); border-radius: var(--r-3); padding: 40px; background: var(--v-night);">
        <div class="t-mono" style="font-size: 11px; color: var(--v-amber); letter-spacing: 0.1em; margin-bottom: 16px;">UTAN VITTRING</div>
        <div style="font-family: var(--font-display); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; color: var(--v-paper); margin-bottom: 24px;">Manuell research, missade fönster.</div>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="display: flex; gap: 12px; padding: 12px 0; border-top: 1px solid var(--v-night-3); font-size: 15px; color: var(--v-mist); line-height: 1.5;"><span style="color: var(--v-amber); font-family: var(--font-mono); flex-shrink: 0;">×</span><span>Säljare letar manuellt i jobbsajter, allabolag och TED varje morgon.</span></li>
          <li style="display: flex; gap: 12px; padding: 12px 0; border-top: 1px solid var(--v-night-3); font-size: 15px; color: var(--v-mist); line-height: 1.5;"><span style="color: var(--v-amber); font-family: var(--font-mono); flex-shrink: 0;">×</span><span>Signaler missas — fel sökord, fel dag, fel källa.</span></li>
          <li style="display: flex; gap: 12px; padding: 12px 0; border-top: 1px solid var(--v-night-3); font-size: 15px; color: var(--v-mist); line-height: 1.5;"><span style="color: var(--v-amber); font-family: var(--font-mono); flex-shrink: 0;">×</span><span>Konkurrenten hinner ringa kunden först.</span></li>
          <li style="display: flex; gap: 12px; padding: 12px 0; border-top: 1px solid var(--v-night-3); font-size: 15px; color: var(--v-mist); line-height: 1.5;"><span style="color: var(--v-amber); font-family: var(--font-mono); flex-shrink: 0;">×</span><span>CRM fylls med kalla leads utan tydlig anledning att ringa.</span></li>
        </ul>
      </div>

      <div style="border: 1px solid var(--v-night-3); border-left: 3px solid var(--v-signal); border-radius: var(--r-3); padding: 40px; background: var(--v-night);">
        <div class="t-mono" style="font-size: 11px; color: var(--v-signal); letter-spacing: 0.1em; margin-bottom: 16px;">MED VITTRING</div>
        <div style="font-family: var(--font-display); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; color: var(--v-paper); margin-bottom: 24px;">Färdig lista 06:30, varje morgon.</div>
