{% extends "_layout.html.j2" %}
{% block content %}

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Sales intelligence · Bemanning</span>
        <h1>Bemanningsförsäljning som utgår från fakta, inte tur.</h1>
        <p class="lead">
          Tre offentliga datakällor, en kurerad digest 06:30. Hitta köparen innan de annonserar uppdraget.
        </p>
        <div class="hero-cta">
          <a href="/auth/signup" class="btn btn-accent btn-lg">Starta provperiod</a>
          <a href="/pricing" class="btn btn-secondary btn-lg">Se priser</a>
        </div>
        <div class="hero-meta">
          <span class="hero-meta-item"><span class="dot"></span> 14 dagar gratis</span>
          <span class="hero-meta-item"><span class="dot"></span> Inget kreditkort</span>
          <span class="hero-meta-item"><span class="dot"></span> EU-data, GDPR</span>
        </div>
      </div>

      <aside class="digest" aria-label="Exempel på dagligt mejl">
        <div class="digest-titlebar">
          <span class="r"></span><span class="y"></span><span class="g"></span>
          <span class="digest-titlebar-label mono">vittring · daily.eml</span>
        </div>
        <div class="digest-body">
          <div class="digest-from">Från Vittring · Tis 5 maj · 06:30</div>
          <div class="digest-subject">14 nya signaler — Lager &amp; logistik, Storstockholm</div>

          <div class="digest-section-title">Storstockholm · Lager &amp; logistik</div>
          <div class="digest-section-meta">5 prioriterade · 9 övriga</div>

          <div class="digest-row">
            <div class="digest-row-meta">
              <span class="badge badge-success">Upphandling</span>
              <span class="digest-row-date mono">04 maj · 16:42</span>
            </div>
            <div class="digest-row-title">Region Stockholm — Ramavtal lagerbemanning</div>
            <div class="digest-row-detail mono">CPV 79620000 · 12 mkr · Anbud senast 12 jun</div>
            <a href="#" class="digest-row-link">Visa upphandling →</a>
          </div>

          <div class="digest-row">
            <div class="digest-row-meta">
              <span class="badge badge-accent">Jobb</span>
              <span class="digest-row-date mono">04 maj · 14:32</span>
            </div>
            <div class="digest-row-title">Postnord Sverige AB söker 18 truckförare</div>
            <div class="digest-row-detail">Rosersberg · SNI 53.100 · Heltid</div>
            <a href="#" class="digest-row-link">Läs annonsen →</a>
          </div>

          <div class="digest-row">
            <div class="digest-row-meta">
              <span class="badge badge-highlight">Bolagsändring</span>
              <span class="digest-row-date mono">04 maj · 09:15</span>
            </div>
            <div class="digest-row-title">Ahlsell Logistik AB · Ny VD</div>
            <div class="digest-row-detail mono">5567 23‑1223 · Hallsberg</div>
            <a href="#" class="digest-row-link">Läs kungörelsen →</a>
          </div>

          <div class="digest-row">
            <div class="digest-row-meta">
              <span class="badge badge-accent">Jobb</span>
              <span class="digest-row-date mono">04 maj · 08:07</span>
            </div>
            <div class="digest-row-title">Schenker AB — 6 lagermedarbetare, kvällsskift</div>
            <div class="digest-row-detail">Jordbro · SNI 52.100 · Visstidsanställning</div>
            <a href="#" class="digest-row-link">Läs annonsen →</a>
          </div>

          <div class="digest-row">
            <div class="digest-row-meta">
              <span class="badge badge-highlight">Bolagsändring</span>
              <span class="digest-row-date mono">03 maj · 22:11</span>
            </div>
            <div class="digest-row-title">Norrlands Logistik AB · Nytt säte, Södertälje</div>
            <div class="digest-row-detail mono">5566 04‑8812 · Tidigare Sundsvall</div>
            <a href="#" class="digest-row-link">Läs kungörelsen →</a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<section class="stats-strip">
  <div class="container">
    <div class="stats-grid">
      <div>
        <div class="stat-num">3</div>
        <div class="stat-label">offentliga datakällor</div>
      </div>
      <div>
        <div class="stat-num mono">06:30</div>
        <div class="stat-label">i din inbox, varje vardag</div>
      </div>
      <div>
        <div class="stat-num">~5 000</div>
        <div class="stat-label">signaler bevakade per dygn</div>
      </div>
      <div>
        <div class="stat-num">EU</div>
        <div class="stat-label">data residency</div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Hur det funkar</span>
      <h2>Från registrering till första samtalet — samma vecka.</h2>
    </div>

    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-icon">01</div>
        <h3>Beskriv din nisch</h3>
        <p>Roller, kommuner, SNI- och CPV-koder, nyckelord. Justera när du vill.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">02</div>
        <h3>Vi filtrerar bruset</h3>
        <p>Matchningsmotorn släpper igenom det som rör dig. 99,5 % förkastas.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">03</div>
        <h3>Du läser ditt mejl</h3>
        <p>06:30 ligger digesten i inboxen. Klart, daterat, direktlänkat.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Datakällor</span>
      <h2>Tre myndighetskällor. Inga gråzoner.</h2>
    </div>

    <div class="source-row">
      <div class="source-item">
        <div class="source-name">JobTech Dev</div>
        <p>Arbetsförmedlingens öppna API. Alla jobbannonser i Sverige, daglig hämtning.</p>
        <span class="source-tag mono">jobsearch.api.jobtechdev.se</span>
      </div>
      <div class="source-item">
        <div class="source-name">Bolagsverket</div>
        <p>Kungörelser om VD, säte, styrelse, namn, likvidationer — dagen efter.</p>
        <span class="source-tag mono">PoIT</span>
      </div>
      <div class="source-item">
        <div class="source-name">TED</div>
        <p>EU:s upphandlingsdatabas, filtrerad på CPV-koder för bemanning.</p>
        <span class="source-tag mono">ted.europa.eu</span>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Priser</span>
      <h2>Tre planer. Avbryt när du vill.</h2>
    </div>

    <div class="pricing-grid">
      <div class="pricing-tier">
        <div class="pricing-tier-name">Solo</div>
        <div class="pricing-tier-price">1 500 kr <span class="per">/ mån</span></div>
        <ul class="pricing-tier-features">
          <li>5 prenumerationer</li>
          <li>1 användare</li>
          <li>Alla tre datakällor</li>
          <li>14 dagars provperiod</li>
        </ul>
        <a href="/auth/signup" class="btn btn-secondary" style="width:100%;">Välj Solo</a>
      </div>

      <div class="pricing-tier featured">
        <div class="pricing-tier-name">Team</div>
        <div class="pricing-tier-price">2 500 kr <span class="per">/ mån</span></div>
        <ul class="pricing-tier-features">
          <li>20 prenumerationer</li>
          <li>5 användare</li>
          <li>Alla tre datakällor</li>
          <li>Delade filter och taggar</li>
        </ul>
        <a href="/auth/signup" class="btn btn-accent" style="width:100%;">Välj Team</a>
      </div>

      <div class="pricing-tier">
        <div class="pricing-tier-name">Pro</div>
        <div class="pricing-tier-price">4 000 kr <span class="per">/ mån</span></div>
        <ul class="pricing-tier-features">
          <li>Obegränsade prenumerationer</li>
          <li>15 användare</li>
          <li>HubSpot-integration</li>
          <li>API-åtkomst</li>
        </ul>
        <a href="/auth/signup" class="btn btn-secondary" style="width:100%;">Välj Pro</a>
      </div>
    </div>

    <p class="subtle" style="margin-top: 16px; text-align: center;">
      Exklusive moms. Årsbetalning ger 10 % rabatt. Volym? <a href="mailto:info@karimkhalil.se">Hör av dig.</a>
    </p>
  </div>
</section>

<div class="section-divider"></div>

<section class="section">
  <div class="container container-narrow">
    <div class="section-head">
      <span class="eyebrow">Vanliga frågor</span>
      <h2>Det vi får mest frågor om.</h2>
    </div>

    <div class="faq">
      <div class="faq-item">
        <div class="faq-q">Är all data offentlig?</div>
        <p class="faq-a">Ja. Svenska och europeiska myndighetskällor via öppna API:er. Ingen scraping, inga gråzoner.</p>
      </div>
      <div class="faq-item">
        <div class="faq-q">Hur snabbt syns en signal?</div>
        <p class="faq-a">Inom 24 timmar från publicering. Hämtning sker tidig morgon, digesten lämnar oss 06:30.</p>
      </div>
      <div class="faq-item">
        <div class="faq-q">Var ligger min data?</div>
        <p class="faq-a">Hetzner Falkenstein, EU. GDPR-säkrad med PUB-avtal med samtliga underbiträden.</p>
      </div>
      <div class="faq-item">
        <div class="faq-q">Kan jag avbryta?</div>
        <p class="faq-a">När som helst, från ditt konto. Ingen uppsägningstid. Provperioden fakturerar inget.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="cta-banner">
      <div class="cta-banner-inner">
        <div>
          <h2>Sluta gissa.</h2>
          <p>Starta provperioden idag. Inget kreditkort, inga åtaganden.</p>
        </div>
        <div style="display:flex; gap: var(--space-3); flex-wrap: wrap;">
          <a href="/auth/signup" class="btn btn-on-dark btn-lg">Starta provperiod</a>
          <a href="mailto:info@karimkhalil.se" class="btn btn-ghost btn-lg" style="color: var(--color-text-inverse);">Boka samtal</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% endblock %}
