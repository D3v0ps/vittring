{# Public, no-auth demo of the Vittring dashboard. Mirrors
   app/dashboard.html.j2 visually but renders without a current_user, no CSRF,
   and routes every write action to /auth/signup. Self-contained — does NOT
   extend _app_shell.html.j2 (which requires user context). #}
<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8">
<title>Demo — Vittring</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="referrer" content="strict-origin-when-cross-origin">
<meta name="robots" content="index,follow">
<meta name="description" content="Se hur Vittring presenterar dagliga säljsignaler från jobbannonser, bolagshändelser och offentliga upphandlingar — exempeldata, ingen inloggning krävs.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/css/brand.css">
<style>
  body { background: var(--v-night); color: var(--v-mist); margin: 0; font-family: var(--font-sans); }
  .dash-shell { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }

  .dash-side {
    background: var(--v-night);
    border-right: 1px solid var(--v-night-3);
    padding: 20px 16px;
    display: flex; flex-direction: column; gap: 24px;
    position: sticky; top: 0; height: 100vh; overflow-y: auto;
  }
  .dash-main { background: var(--v-night-2); }
  .nav-section h5 {
    font-family: var(--font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--v-ink-4); margin: 0 0 8px; padding: 0 8px; font-weight: 500;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 10px; border-radius: 6px;
    font-size: 13px; color: var(--v-mist); cursor: pointer;
    text-decoration: none;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .nav-item:hover { background: var(--v-night-3); color: var(--v-paper); }
  .nav-item.active { background: rgba(184,224,74,0.1); color: var(--v-signal); }
  .nav-item .count {
    margin-left: auto; font-family: var(--font-mono); font-size: 11px;
    color: var(--v-ink-4);
  }
  .nav-item.active .count { color: var(--v-signal); }

  .demo-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--v-amber-3); color: var(--v-amber);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 4px; font-weight: 500;
  }

  .topbar {
    height: 60px; padding: 0 32px;
    border-bottom: 1px solid var(--v-night-3);
    display: flex; justify-content: space-between; align-items: center;
    background: var(--v-night);
    gap: 16px;
  }

  .topbar-banner {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--v-amber-3); color: var(--v-amber);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 999px; font-weight: 500;
  }

  .demo-banner {
    background: var(--v-night-3);
    padding: 12px 32px;
    border-bottom: 1px solid var(--v-night-3);
    font-family: var(--font-mono); font-size: 12px;
    color: var(--v-mist);
    position: sticky; top: 0; z-index: 5;
  }
  .demo-banner a { color: var(--v-signal); text-decoration: underline; }

  .digest-header {
    padding: 32px;
    border-bottom: 1px solid var(--v-night-3);
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 32px;
  }

  .stat-card .lbl { font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); letter-spacing: 0.1em; text-transform: uppercase; }
  .stat-card .num { font-family: var(--font-display); font-size: 40px; line-height: 1; color: var(--v-paper); margin-top: 6px; letter-spacing: -0.025em; }
  .stat-card .delta { font-family: var(--font-mono); font-size: 12px; color: var(--v-signal); margin-left: 6px; }

  .filter-bar {
    padding: 16px 32px;
    border-bottom: 1px solid var(--v-night-3);
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
  }
  .chip {
    background: var(--v-night-3); border: 1px solid transparent;
    padding: 6px 10px; border-radius: 999px;
    font-family: var(--font-mono); font-size: 11px; color: var(--v-mist);
    display: inline-flex; align-items: center; gap: 6px; cursor: pointer;
  }
  .chip.active { background: rgba(184,224,74,0.12); color: var(--v-signal); border-color: rgba(184,224,74,0.3); }
  .chip .x { opacity: 0.5; cursor: pointer; }

  .feed { padding: 0; }
  .row {
    display: grid; grid-template-columns: 80px 100px 1fr 200px 120px;
    gap: 16px; padding: 14px 32px;
    border-bottom: 1px solid var(--v-night-3);
    align-items: center;
    transition: background 0.15s;
  }
  .row:hover { background: rgba(200,204,196,0.03); }
  .row.priority { background: rgba(184,224,74,0.04); border-left: 3px solid var(--v-signal); padding-left: 29px; }
  .row .time { font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); white-space: nowrap; }
  .row.priority .time { color: var(--v-signal); }
  .row .title { color: var(--v-paper); font-size: 14px; font-weight: 500; }
  .row .meta { font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); margin-top: 3px; }
  .row .src { font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); }
  .row .actions { display: flex; gap: 4px; opacity: 0; transition: opacity 0.15s; }
  .row:hover .actions { opacity: 1; }

  .icon-btn {
    background: transparent; border: 1px solid var(--v-night-3);
    color: var(--v-mist); padding: 5px 9px; border-radius: 5px;
    font-size: 11px; cursor: pointer; font-family: var(--font-mono);
    text-decoration: none; display: inline-flex; align-items: center; gap: 4px;
  }
  .icon-btn:hover { background: var(--v-night-3); color: var(--v-paper); }
  .icon-btn.primary { background: var(--v-signal); color: var(--v-signal-ink); border-color: transparent; }
  .icon-btn.primary:hover { background: var(--v-signal-2); }
  .icon-btn.disabled {
    opacity: 0.5; cursor: not-allowed; pointer-events: none;
    color: var(--v-ink-4);
  }

  .panel-title { font-family: var(--font-display); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; color: var(--v-paper); margin: 0; }
  .panel-sub { font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); margin-top: 4px; letter-spacing: 0.06em; }

  .pill-kind {
    font-family: var(--font-mono); font-size: 10px;
    padding: 2px 7px; border-radius: 999px; display: inline-block;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .pill-kind.upph { background: rgba(200,117,62,0.15); color: var(--v-amber); }
  .pill-kind.jobb { background: var(--v-night-3); color: var(--v-mist); }
  .pill-kind.bolag { background: rgba(184,224,74,0.1); color: var(--v-signal); }

  .signup-cta {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--v-signal); color: var(--v-signal-ink);
    border: 1px solid transparent; padding: 8px 14px; border-radius: 6px;
    font-family: var(--font-mono); font-size: 12px; font-weight: 500;
    text-decoration: none; letter-spacing: 0.04em;
    transition: background 0.12s ease;
  }
  .signup-cta:hover { background: var(--v-signal-2); }

  .sidebar-cta {
    display: block; text-align: center;
    background: var(--v-signal); color: var(--v-signal-ink);
    padding: 10px 12px; border-radius: 6px;
    font-family: var(--font-mono); font-size: 12px; font-weight: 500;
    text-decoration: none;
    transition: background 0.12s ease;
  }
  .sidebar-cta:hover { background: var(--v-signal-2); }

  .end-cta {
    margin: 32px; padding: 32px;
    background: var(--v-night-3); border: 1px solid rgba(184,224,74,0.18);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
  }
  .end-cta .end-cta-text {
    font-family: var(--font-display); font-size: 22px;
    color: var(--v-paper); letter-spacing: -0.015em; max-width: 640px;
  }
  .end-cta .end-cta-sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--v-ink-4); margin-top: 6px; letter-spacing: 0.06em;
  }
</style>
</head>
<body data-screen-label="Demo">

<div class="dash-shell">

  <!-- SIDEBAR -->
  <aside class="dash-side">
    <a href="/" style="display: flex; align-items: center; gap: 10px; padding: 4px 8px; text-decoration: none;">
      <svg width="22" height="22" viewBox="0 0 22 22">
        <circle cx="11" cy="11" r="10" fill="none" stroke="var(--v-paper)" stroke-width="1"/>
        <circle cx="11" cy="11" r="6" fill="none" stroke="var(--v-paper)" stroke-width="1"/>
        <circle cx="11" cy="11" r="2.2" fill="var(--v-signal)"/>
      </svg>
      <span style="font-family: var(--font-display); font-size: 18px; color: var(--v-paper); font-weight: 500; letter-spacing: -0.025em;">Vittring</span>
    </a>

    <div class="nav-section">
      <h5>Idag</h5>
      <a href="/demo" class="nav-item active">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="7" cy="7" r="6"/><circle cx="7" cy="7" r="3"/><circle cx="7" cy="7" r="1" fill="currentColor"/></svg>
        Dagens digest <span class="count">{{ digest_count }}</span>
      </a>
      <a href="/auth/signup" class="nav-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="2" width="10" height="10" rx="1"/><path d="M2 5 L12 5"/></svg>
        Kalender
      </a>
    </div>

    <div class="nav-section">
      <h5 style="display: flex; align-items: center; justify-content: space-between; padding-right: 8px;">
        <span>Du tittar på exempel</span>
        <span class="demo-badge">DEMO</span>
      </h5>
      {% for sub in subscriptions %}
      <a href="/auth/signup" class="nav-item">⚑ {{ sub.name }} <span class="count">{{ sub.signal_count }} nya</span></a>
      {% endfor %}
    </div>

    <div class="nav-section">
      <h5>Bibliotek</h5>
      <a href="/auth/signup" class="nav-item">★ Sparade signaler</a>
      <a href="/auth/signup" class="nav-item">⏷ Arkiv</a>
      <a href="/auth/signup" class="nav-item">⌗ Taggar</a>
    </div>

    <div style="margin-top: auto; padding: 12px 4px; border-top: 1px solid var(--v-night-3);">
      <a href="/auth/signup" class="sidebar-cta">Skapa eget konto →</a>
      <div style="font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); margin-top: 10px; text-align: center; letter-spacing: 0.04em;">
        14 dagars provperiod · inget kreditkort
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="dash-main">

    <!-- TOPBAR -->
    <div class="topbar">
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); text-transform: uppercase; letter-spacing: 0.08em;">{{ today_weekday }}</span>
        <span style="font-family: var(--font-display); font-size: 16px; color: var(--v-paper); font-weight: 500;">{{ today_date }}</span>
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--v-signal); margin-left: 8px;">● Synkad {{ last_sync_time }}</span>
      </div>
      <div style="display: flex; gap: 12px; align-items: center;">
        <span class="topbar-banner" aria-label="Exempeldata">EXEMPELDATA</span>
        <a href="/auth/signup" class="signup-cta">+ Starta gratis provperiod</a>
      </div>
    </div>

    <!-- STICKY DEMO BANNER -->
    <div class="demo-banner">
      Det här är en demo med exempeldata. För att få egna signaler dagligen — <a href="/auth/signup">starta provperioden</a>.
    </div>

    <!-- DIGEST HEADER -->
    <div class="digest-header">
      <div>
        <div class="panel-sub" style="color: var(--v-signal);">↗ DAGENS DIGEST</div>
        <h1 class="panel-title" style="font-size: 40px; margin-top: 8px;">{{ digest_count }} {{ "ny signal" if digest_count == 1 else "nya signaler" }}</h1>
        <div style="font-size: 14px; color: var(--v-mist); margin-top: 6px;">
          {{ digest_focus }}.
          <span style="color: var(--v-ink-4);">{{ priority_count }} prioriterade matchar din profil exakt.</span>
        </div>
        <div style="display: flex; gap: 8px; margin-top: 16px;">
          <span class="chip active">{{ priority_count }} prioriterade</span>
          <span class="chip">{{ other_count }} övriga</span>
          <span class="chip">{{ saved_count }} sparade</span>
        </div>
      </div>

      <div class="stat-card">
        <div class="lbl">Senaste 7 dygn</div>
        <div><span class="num">{{ stat_week_count }}</span><span class="delta">{{ stat_week_delta }}</span></div>
        <svg viewBox="0 0 200 40" style="width: 100%; margin-top: 8px;">
          <polyline points="0,30 25,28 50,24 75,26 100,18 125,20 150,12 175,14 200,8" fill="none" stroke="var(--v-signal)" stroke-width="1.4"/>
          <circle cx="200" cy="8" r="3" fill="var(--v-signal)"/>
        </svg>
      </div>

      <div class="stat-card">
        <div class="lbl">Förkastat brus</div>
        <div><span class="num">{{ stat_noise_pct }}</span></div>
        <div style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); margin-top: 8px;">av {{ stat_noise_total }} inkomna</div>
      </div>

      <div class="stat-card">
        <div class="lbl">Konverteringar v.{{ stat_week_num }}</div>
        <div><span class="num">{{ stat_conversions }}</span><span class="delta">{{ stat_conversions_delta }}</span></div>
        <div style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); margin-top: 8px;">samtal → kvalif. lead</div>
      </div>
    </div>

    <!-- FILTER -->
    <div class="filter-bar">
      <span style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); margin-right: 8px;">FILTRERA:</span>
      <span class="chip active">Alla typer <span class="x">×</span></span>
      <span class="chip">Upphandlingar ({{ count_upph }})</span>
      <span class="chip">Jobb ({{ count_jobb }})</span>
      <span class="chip">Bolagsändringar ({{ count_bolag }})</span>
      <span style="width: 1px; height: 18px; background: var(--v-night-3); margin: 0 8px;"></span>
      {% for f in active_filters %}
      <span class="chip active">{{ f }} <span class="x">×</span></span>
      {% endfor %}
      <span class="chip">+ filter</span>
      <span style="margin-left: auto; font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4);">Sortera: <span style="color: var(--v-mist);">Tid ↓</span></span>
    </div>

    <!-- FEED -->
    <div class="feed">
      {% for signal in priority_signals %}
      <div class="row priority">
        <span class="time">{{ signal.date }}<br><span style="color: var(--v-ink-4);">{{ signal.time }}</span></span>
        <span class="pill-kind {{ signal.kind_class }}">{{ signal.kind }}</span>
        <div>
          <div class="title">{{ signal.title }}</div>
          <div class="meta">{{ signal.meta }}</div>
        </div>
        <div class="src">{{ signal.source }}</div>
        <div class="actions">
          <a href="/auth/signup" class="icon-btn" title="Skapa konto för att spara signaler">★</a>
          <span class="icon-btn disabled" title="Pro-funktion">↗ HubSpot</span>
          <a class="icon-btn primary" href="{{ signal.url or '#' }}"{% if signal.url %} target="_blank" rel="noopener"{% endif %}>Öppna →</a>
        </div>
      </div>
      {% endfor %}

      {% if other_signals %}
      <div style="padding: 16px 32px; border-bottom: 1px solid var(--v-night-3); font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); letter-spacing: 0.1em; text-transform: uppercase;">
        ─── {{ other_count }} ÖVRIGA ───
      </div>

      {% for signal in other_signals %}
      <div class="row">
        <span class="time">{{ signal.date }}<br><span style="color: var(--v-ink-4);">{{ signal.time }}</span></span>
        <span class="pill-kind {{ signal.kind_class }}">{{ signal.kind }}</span>
        <div>
          <div class="title">{{ signal.title }}</div>
          <div class="meta">{{ signal.meta }}</div>
        </div>
        <div class="src">{{ signal.source }}</div>
        <div class="actions">
          <a href="/auth/signup" class="icon-btn" title="Skapa konto för att spara signaler">★</a>
          <span class="icon-btn disabled" title="Pro-funktion">↗</span>
          <a class="icon-btn" href="{{ signal.url or '#' }}"{% if signal.url %} target="_blank" rel="noopener"{% endif %} title="Öppna källa">→</a>
        </div>
      </div>
      {% endfor %}
      {% endif %}

      <div style="padding: 24px 32px; text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4);">
        — Slut på exempeldigesten. Riktiga signaler levereras 06:30 varje vardag. —
      </div>
    </div>

    <!-- END CTA -->
    <section class="end-cta">
      <div>
        <div class="end-cta-text">
          Vill du se hur signaler ser ut för din nisch? Starta 14 dagars provperiod — inget kreditkort.
        </div>
        <div class="end-cta-sub">
          DAGLIG DIGEST · 06:30 · TRE KÄLLOR · KONFIGURERA PÅ 5 MIN
        </div>
      </div>
      <a href="/auth/signup" class="signup-cta" style="font-size: 13px; padding: 12px 18px;">+ Starta gratis provperiod →</a>
    </section>
  </main>
</div>

</body>
</html>
