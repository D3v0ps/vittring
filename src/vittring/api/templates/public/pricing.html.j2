{% extends "_layout.html.j2" %}
{% block content %}
<style>
  .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1200px; margin: 0 auto; }
  @media (max-width: 920px) { .price-grid { grid-template-columns: 1fr; } }
  .price-card {
    background: var(--v-night-2); border: 1px solid var(--v-night-3);
    border-radius: var(--r-3); padding: 40px 32px;
    display: flex; flex-direction: column;
  }
  .price-card.featured {
    border-color: var(--v-signal);
    box-shadow: 0 0 0 1px var(--v-signal), var(--shadow-night);
    position: relative;
  }
  .price-card.featured::before {
    content: 'Mest valda';
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--v-signal); color: var(--v-signal-ink);
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    padding: 4px 10px; border-radius: var(--r-pill);
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .price-name { font-family: var(--font-display); font-size: 28px; font-weight: 500; letter-spacing: -0.02em; color: var(--v-paper); margin-bottom: 4px; }
  .price-tag { font-size: 14px; color: var(--v-mist); margin-bottom: 32px; line-height: 1.4; }
  .price-amount { display: flex; align-items: baseline; gap: 6px; margin-bottom: 24px; }
  .price-amount .num { font-family: var(--font-display); font-size: 56px; font-weight: 400; letter-spacing: -0.03em; color: var(--v-paper); line-height: 1; }
  .price-amount .per { font-family: var(--font-mono); font-size: 12px; color: var(--v-ink-4); }
  .price-features { list-style: none; padding: 0; margin: 0 0 32px; flex-grow: 1; }
  .price-features li { display: flex; gap: 10px; align-items: flex-start; padding: 8px 0; font-size: 14px; color: var(--v-mist); border-top: 1px solid rgba(200,204,196,0.08); }
  .price-features li:first-child { border-top: none; }
  .price-features li.off { color: var(--v-ink-4); }
  .price-features svg { flex-shrink: 0; margin-top: 3px; }

  .toggle {
    display: inline-flex; background: var(--v-night-2);
    border: 1px solid var(--v-night-3); border-radius: var(--r-pill);
    padding: 4px; gap: 4px;
  }
  .toggle button {
    background: transparent; border: none; color: var(--v-mist);
    padding: 8px 16px; border-radius: var(--r-pill);
    font-family: var(--font-mono); font-size: 12px; font-weight: 500;
    cursor: pointer; transition: all 0.15s ease;
  }
  .toggle button.active { background: var(--v-signal); color: var(--v-signal-ink); }
  .toggle .save { font-size: 10px; color: var(--v-signal); margin-left: 6px; }

  .price-note {
    max-width: 1200px; margin: 0 auto 32px; padding: 16px 20px;
    background: var(--v-night-3); border: 1px solid rgba(200,204,196,0.08);
    border-radius: var(--r-2);
    font-family: var(--font-mono); font-size: 12px; color: var(--v-mist);
    text-align: center; letter-spacing: 0.02em;
  }

  .compare-wrap { max-width: 1200px; margin: 64px auto 0; }
  .compare-title { font-family: var(--font-display); font-size: 32px; font-weight: 500; letter-spacing: -0.02em; color: var(--v-paper); margin: 0 0 8px; text-align: center; }
  .compare-sub { font-size: 14px; color: var(--v-mist); margin: 0 0 32px; text-align: center; }
  .compare-table {
    width: 100%; border-collapse: collapse;
    background: var(--v-night-2);
    border: 1px solid var(--v-night-3);
    border-radius: var(--r-3); overflow: hidden;
  }
  .compare-table th, .compare-table td {
    padding: 14px 20px; text-align: left;
    border-top: 1px solid rgba(200,204,196,0.08);
    font-size: 14px; color: var(--v-mist); vertical-align: middle;
  }
  .compare-table thead th {
    border-top: none;
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--v-paper); background: var(--v-night-3);
  }
  .compare-table tbody tr.section-row td {
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--v-ink-4); background: rgba(200,204,196,0.03);
    padding: 10px 20px;
  }
  .compare-table th:not(:first-child),
  .compare-table td:not(:first-child) { text-align: center; width: 16%; }
  .compare-table .col-team { background: rgba(99,209,156,0.04); }
  .compare-table .icon-yes,
  .compare-table .icon-no,
  .compare-table .icon-text { display: inline-flex; align-items: center; justify-content: center; }
  .compare-table .icon-text { color: var(--v-paper); font-family: var(--font-mono); font-size: 12px; }
  .compare-table .row-feat { color: var(--v-paper); font-weight: 500; }
  .compare-table .row-sub { display: block; color: var(--v-ink-4); font-size: 12px; font-weight: 400; margin-top: 2px; }

  .price-microcopy {
    max-width: 1200px; margin: 24px auto 0; text-align: center;
    font-family: var(--font-mono); font-size: 12px; color: var(--v-ink-4);
  }
  .price-microcopy a { color: var(--v-signal); }

  /* FAQ */
  .faq-wrap { max-width: 760px; margin: 0 auto; }
  .faq-wrap details {
    border-top: 1px solid var(--v-night-3); padding: 20px 0;
  }
  .faq-wrap details:last-child { border-bottom: 1px solid var(--v-night-3); }
  .faq-wrap summary {
    list-style: none; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-display); font-size: 20px; font-weight: 500;
    color: var(--v-paper); letter-spacing: -0.01em;
  }
  .faq-wrap summary::-webkit-details-marker { display: none; }
  .faq-wrap summary .plus {
    font-family: var(--font-mono); font-size: 20px; color: var(--v-signal);
    transition: transform 0.2s ease;
  }
  .faq-wrap details[open] summary .plus { transform: rotate(45deg); }
  .faq-wrap .faq-a { margin-top: 12px; font-size: 15px; color: var(--v-mist); line-height: 1.6; }
</style>

<!-- HEADER -->
