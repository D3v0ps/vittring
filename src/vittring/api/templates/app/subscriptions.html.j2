{% extends "app/_app_shell.html.j2" %}
{% set topbar_eyebrow = "Prenumerationer" %}
{% set title = "Dina prenumerationer" %}
{% block topbar_actions %}
<a href="/app/subscriptions/new" class="v-btn v-btn--signal">Skapa prenumeration</a>
{% endblock %}
{% block app_content %}
<header class="page-head">
  <div class="page-eyebrow">Prenumerationer</div>
  <h1 class="page-title">Dina prenumerationer</h1>
  <p class="page-lead">
    Definiera vad som matchar i den dagliga digesten.
    {% if subscriptions %}
      Du har {{ subscriptions|length }} aktiv{{ "" if subscriptions|length == 1 else "a" }} just nu.
      Träffar levereras till <span style="font-family: var(--font-mono); color: var(--v-paper);">{{ user.email }}</span> kl 06:30.
    {% endif %}
  </p>
</header>

{% if subscriptions %}
<section class="v-card" style="padding: 0;">
  {% for sub in subscriptions %}
  <div style="display: grid; grid-template-columns: minmax(200px, 1.4fr) minmax(160px, 1fr) auto auto auto; gap: 20px; padding: 18px 24px; align-items: center; {% if not loop.first %}border-top: 1px solid var(--v-night-3);{% endif %}">
    <div>
      <div style="color: var(--v-paper); font-weight: 500; font-size: 14px; margin-bottom: 4px;">{{ sub.name }}</div>
      <div style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4);">#{{ sub.id }}</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
      {% for st in sub.signal_types %}
        {% if st == "job" %}
          <span class="v-pill v-pill--neutral">Jobb</span>
        {% elif st == "company_change" %}
          <span class="v-pill v-pill--signal">Bolag</span>
        {% elif st == "procurement" %}
          <span class="v-pill v-pill--amber">Upphandling</span>
        {% else %}
          <span class="v-pill v-pill--neutral">{{ st }}</span>
        {% endif %}
      {% endfor %}
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      {% if sub.active %}
        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--v-signal); box-shadow: 0 0 8px rgba(184,224,74,0.5);"></span>
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--v-signal); letter-spacing: 0.04em;">Aktiv</span>
      {% else %}
        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--v-ink-4);"></span>
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4); letter-spacing: 0.04em;">Pausad</span>
      {% endif %}
    </div>
    <div style="font-family: var(--font-mono); font-size: 11px; color: var(--v-ink-4);">
      {{ sub.created_at.strftime("%Y-%m-%d") }}
    </div>
    <div style="display: flex; gap: 8px;">
      <a href="/app/subscriptions/new?duplicate={{ sub.id }}" class="v-btn v-btn--ghost" style="padding: 6px 12px; font-size: 11px;">Duplicera</a>
      <form method="post" action="/app/subscriptions/{{ sub.id }}/delete" style="display: inline;"
            onsubmit="return confirm('Radera prenumerationen {{ sub.name }}?');">
        {{ csrf_input() }}
        <button type="submit" class="v-btn v-btn--danger" style="padding: 6px 12px; font-size: 11px;">Radera</button>
      </form>
    </div>
  </div>
  {% endfor %}
</section>
{% else %}
<section class="v-card" style="text-align: center; padding: 48px 24px;">
  <div style="font-family: var(--font-display); font-size: 22px; color: var(--v-paper); margin-bottom: 8px; letter-spacing: -0.015em;">Inga prenumerationer ännu</div>
  <p style="color: var(--v-mist); font-size: 14px; max-width: 480px; margin: 0 auto 20px; line-height: 1.6;">
    En prenumeration är ditt filter — t.ex. &rdquo;Lagerarbetare Storstockholm&rdquo;
    eller &rdquo;Konsultchefer norra Sverige&rdquo;. Vi matchar mot tre datakällor och
    levererar träffar i en daglig digest kl 06:30.
  </p>
  <div style="display: flex; gap: 10px; justify-content: center; margin-bottom: 24px;">
    <a href="/app/subscriptions/new" class="v-btn v-btn--signal v-btn--lg">Skapa första prenumerationen</a>
  </div>
  <div style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; align-items: center;">
    <span style="font-family: var(--font-mono); font-size: 10px; color: var(--v-ink-4); letter-spacing: 0.08em; text-transform: uppercase;">Exempel</span>
    <span class="v-pill v-pill--neutral">Lagerarbetare Storstockholm</span>
    <span class="v-pill v-pill--neutral">Truckförare Skåne län</span>
    <span class="v-pill v-pill--neutral">Konsultchefer norra Sverige</span>
  </div>
</section>
{% endif %}
{% endblock %}
