{% extends "app/_app_shell.html.j2" %}
{% set topbar_eyebrow = "Prenumerationer" %}
{% set title = "Skapa prenumeration" %}
{% block topbar_actions %}
<div style="display: flex; gap: 8px;">
  <a href="/app/subscriptions" class="v-btn v-btn--ghost">Avbryt</a>
  <button type="submit" form="sub-form" class="v-btn v-btn--signal">Skapa prenumeration</button>
</div>
{% endblock %}
{% block app_content %}
<header class="page-head">
  <div class="page-eyebrow">Ny prenumeration</div>
  <h1 class="page-title">Skapa prenumeration</h1>
  <p class="page-lead">
    Välj signaltyper och förfina med geografi, bransch och nyckelord.
    Lämna fält tomma för bredare träffar — du kan justera när som helst.
  </p>
</header>

{% if error %}<div class="v-alert">{{ error }}</div>{% endif %}

<form method="post" action="/app/subscriptions/" id="sub-form">
  {{ csrf_input() }}

  <section class="v-card">
    <div class="v-card-head">
      <div>
        <h2>1. Namn och signaltyper</h2>
        <p>Ge prenumerationen ett internt namn och välj minst en signaltyp.</p>
      </div>
    </div>

    <div class="v-field">
      <label class="v-label" for="name">Internt namn</label>
      <input class="v-input" id="name" name="name" required maxlength="120"
             placeholder="t.ex. Lagerarbetare Storstockholm" autocomplete="off" />
      <p class="v-hint">Bara du ser detta — använd det för att skilja prenumerationer åt.</p>
    </div>

    <div class="v-field" style="margin-top: 24px;">
      <label class="v-label">Signaltyper</label>
      <p class="v-hint" style="margin: 0 0 12px;">Minst en. Fält längre ner visas baserat på dina val.</p>

      <div class="signal-grid">
        <label class="signal-card">
          <input type="checkbox" name="signal_types" value="job" checked data-signal="job" />
          <span class="signal-card-body">
            <span class="signal-card-title">Jobbannonser</span>
            <span class="signal-card-desc">Volymrekryteringar och nya tjänster — tidig signal på växande personalbehov.</span>
          </span>
        </label>

        <label class="signal-card">
          <input type="checkbox" name="signal_types" value="company_change" data-signal="company_change" />
          <span class="signal-card-body">
            <span class="signal-card-title">Bolagshändelser</span>
            <span class="signal-card-desc">Ny VD, ny styrelse, nytt säte. Köpare som omförhandlar — fönster för dig.</span>
          </span>
        </label>

        <label class="signal-card">
          <input type="checkbox" name="signal_types" value="procurement" data-signal="procurement" />
          <span class="signal-card-body">
            <span class="signal-card-title">Upphandlingar</span>
            <span class="signal-card-desc">Offentliga ramavtal och uppdrag inom bemanning och rekrytering.</span>
          </span>
        </label>
      </div>
    </div>
  </section>

  <section class="v-card">
    <div class="v-card-head">
      <div>
        <h2>2. Geografi och bransch</h2>
        <p>Begränsa till områden och branscher som matchar din affär.</p>
      </div>
    </div>

    <div class="v-field" data-needs="job procurement company_change">
      <label class="v-label" for="municipalities">Kommuner <span class="opt">valfritt</span></label>
      <input class="v-input" id="municipalities" name="municipalities"
             placeholder="Stockholm, Södertälje, Botkyrka" autocomplete="off" />
      <p class="v-hint">Kommaseparerat. Exakta namn — t.ex. <span class="mono">Göteborg, Mölndal</span>.</p>
    </div>

    <div class="v-field" data-needs="job company_change">
      <label class="v-label" for="counties">Län <span class="opt">valfritt</span></label>
      <input class="v-input" id="counties" name="counties"
             placeholder="Stockholms län, Uppsala län" autocomplete="off" />
      <p class="v-hint">Bredare än kommuner. Skriv hela namnet inklusive <span class="mono">län</span>.</p>
    </div>

    <div class="v-field" data-needs="job">
      <label class="v-label" for="occupations">Yrkesroller <span class="opt">valfritt</span></label>
      <input class="v-input" id="occupations" name="occupations"
             placeholder="Lagerarbetare, Truckförare, Chaufför C/CE" autocomplete="off" />
      <p class="v-hint">Kommaseparerat. Söker i annonsens roll- och titelfält.</p>
    </div>

    <div class="v-field" data-needs="company_change">
      <label class="v-label" for="sni_codes">SNI-koder <span class="opt">valfritt</span></label>
      <input class="v-input mono" id="sni_codes" name="sni_codes"
             placeholder="49410, 52100" pattern="[0-9, ]*" autocomplete="off" />
      <p class="v-hint">Branschklassificering från SCB. Exempel: <span class="mono">49410</span> (godstrafik), <span class="mono">52100</span> (lager och magasin).</p>
    </div>
  </section>

  <section class="v-card">
    <div class="v-card-head">
      <div>
        <h2>3. Nyckelord och finjustering</h2>
        <p>Inkludera eller utesluta för att skala bort brus.</p>
      </div>
    </div>

    <div class="v-field" data-needs="job procurement">
      <label class="v-label" for="keywords_any">Inkluderande nyckelord <span class="opt">valfritt</span></label>
      <input class="v-input" id="keywords_any" name="keywords_any"
             placeholder="bemanning, interim, konsult" autocomplete="off" />
      <p class="v-hint">Träff om <strong>minst ett</strong> ord finns i texten.</p>
    </div>

    <div class="v-field" data-needs="job procurement">
      <label class="v-label" for="keywords_none">Exkluderande nyckelord <span class="opt">valfritt</span></label>
      <input class="v-input" id="keywords_none" name="keywords_none"
             placeholder="praktik, sommarjobb, volontär" autocomplete="off" />
      <p class="v-hint">Träff <strong>filtreras bort</strong> om något av orden förekommer.</p>
    </div>

    <div class="v-field" data-needs="procurement">
      <label class="v-label" for="cpv_codes">CPV-koder <span class="opt">valfritt</span></label>
      <input class="v-input mono" id="cpv_codes" name="cpv_codes"
             placeholder="79600000, 79610000" pattern="[0-9, ]*" autocomplete="off" />
      <p class="v-hint">EU:s standardklassificering för upphandlingar. Lämna tomt för alla bemannings­relaterade.</p>
    </div>

    <div class="v-field" data-needs="procurement">
      <label class="v-label" for="min_procurement_value_sek">Lägsta upphandlingsvärde (SEK) <span class="opt">valfritt</span></label>
      <input class="v-input mono" id="min_procurement_value_sek" name="min_procurement_value_sek"
             type="number" min="0" step="100000" placeholder="500000" autocomplete="off" />
      <p class="v-hint">Filtrerar bort små ramavtal. Standardvärde är 0 (visa alla).</p>
    </div>
  </section>

  <div style="display: flex; gap: 12px; margin-top: 24px;">
    <button type="submit" class="v-btn v-btn--signal v-btn--lg">Skapa prenumeration</button>
    <a href="/app/subscriptions" class="v-btn v-btn--ghost v-btn--lg">Avbryt</a>
  </div>
</form>
{% endblock %}

{% block head_extra %}
<style>
  .signal-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  }
  @media (max-width: 880px) { .signal-grid { grid-template-columns: 1fr; } }
  .signal-card {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 16px; border: 1px solid var(--v-night-3);
    border-radius: 8px; cursor: pointer;
    transition: border-color 0.12s ease, background 0.12s ease;
    background: var(--v-night-2);
  }
  .signal-card:hover { border-color: rgba(184,224,74,0.3); }
  .signal-card:has(input:checked) {
    border-color: var(--v-signal); background: rgba(184,224,74,0.05);
  }
  .signal-card input[type="checkbox"] { margin: 2px 0 0; flex-shrink: 0; accent-color: var(--v-signal); }
  .signal-card-body { display: flex; flex-direction: column; gap: 4px; }
  .signal-card-title {
    font-family: var(--font-display); font-size: 15px; font-weight: 500;
    color: var(--v-paper); letter-spacing: -0.01em;
  }
  .signal-card-desc { font-size: 12px; color: var(--v-mist); line-height: 1.5; }
</style>
<script>
(() => {
  const form = document.getElementById('sub-form');
  if (!form) return;
  const checkboxes = form.querySelectorAll('input[name="signal_types"]');
  const fields = form.querySelectorAll('[data-needs]');
  function refresh() {
    const active = new Set(
      Array.from(checkboxes).filter(c => c.checked).map(c => c.dataset.signal)
    );
    fields.forEach(f => {
      const needs = (f.dataset.needs || '').split(' ').filter(Boolean);
      const visible = needs.some(n => active.has(n));
      f.style.display = visible ? '' : 'none';
      f.querySelectorAll('input').forEach(i => { i.disabled = !visible; });
    });
  }
  checkboxes.forEach(c => c.addEventListener('change', refresh));
  refresh();
})();
</script>
{% endblock %}
