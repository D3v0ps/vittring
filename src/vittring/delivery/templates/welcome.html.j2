{% extends "_base.html.j2" %}
{% block content %}
<h1 style="margin: 0 0 16px 0; font-size: 22px; font-weight: 500; letter-spacing: -0.02em; color: #141414; line-height: 1.2;">
  Välkommen till Vittring
</h1>
<p style="margin: 0 0 16px 0; font-size: 16px; color: #141414; line-height: 1.65;">
  Hej {{ full_name or "" }},
</p>
<p style="margin: 0 0 16px 0; font-size: 16px; color: #141414; line-height: 1.65;">
  Tack för att du provar Vittring. Du har en kostnadsfri provperiod på 14 dagar — börja med att lägga till din första prenumeration så börjar vi bevaka jobbannonser, bolagsändringar och offentliga upphandlingar utifrån dina kriterier.
</p>
<p style="margin: 24px 0;">
  <a href="{{ dashboard_url }}" style="display:inline-block;height:36px;line-height:36px;padding:0 16px;background:#1B3A4B;color:#FAFAF7;border-radius:6px;font-size:14px;font-weight:500;text-decoration:none;">
    Gå till mitt konto
  </a>
</p>
<p style="margin: 0; font-size: 14px; color: #5C5C58; line-height: 1.65;">
  Frågor? Svara på det här mejlet — det går till {{ from_address }}.
</p>
{% endblock %}
