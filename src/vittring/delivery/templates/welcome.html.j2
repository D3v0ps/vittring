{% extends "_base.html.j2" %}

{% block preheader %}Välkommen till Vittring — kom igång med din första prenumeration.{% endblock %}

{% block header_meta %}Välkommen{% endblock %}

{% block content %}
<p style="margin:0 0 8px 0;font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#2E6CDB;">
  Välkommen
</p>
<h1 style="margin:0 0 20px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:30px;font-weight:600;letter-spacing:-0.025em;color:#0B1220;line-height:1.15;">
  Hej{% if full_name %} {{ full_name }}{% endif %} — välkommen till Vittring.
</h1>
<p style="margin:0 0 28px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:16px;color:#475569;line-height:1.65;">
  Tack för att du provar Vittring. Du har en kostnadsfri provperiod på 14 dagar. Lägg till din första prenumeration så börjar vi bevaka jobbannonser, bolagsändringar och offentliga upphandlingar utifrån dina kriterier — och skickar en samlad signaldigest varje morgon.
</p>

{# CTA button — built as a padded link inside a table for Outlook compatibility #}
<table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:8px 0 32px 0;">
  <tr>
    <td align="center" bgcolor="#2E6CDB" style="background:#2E6CDB;border-radius:8px;">
      <a href="{{ dashboard_url }}" style="display:inline-block;padding:14px 28px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:15px;font-weight:600;color:#FFFFFF;text-decoration:none;letter-spacing:-0.005em;border-radius:8px;">
        Gå till mitt konto &rarr;
      </a>
    </td>
  </tr>
</table>

<p style="margin:0;padding-top:24px;border-top:1px solid #E5E7EB;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:13px;color:#94A3B8;line-height:1.65;">
  Frågor? Svara på det här mejlet — det går till {{ from_address }}.
</p>
{% endblock %}

{% block footer_extra %}
Du får detta mejl eftersom du registrerade ett konto på Vittring.
{% endblock %}
